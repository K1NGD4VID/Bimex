# Stellar / Soroban
VITE_CONTRACT_ID=
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_TOKEN_MXNE=
VITE_MXNE_ISSUER=
VITE_HORIZON_URL=
VITE_ADMIN_ADDRESS=

# Passkey Wallet & Gasless
VITE_PASSKEY_WASM_HASH=
VITE_LAUNCHTUBE_URL=https://testnet.launchtube.xyz
VITE_LAUNCHTUBE_JWT=
# Indexer API URL (for faucet and data queries)
VITE_API_URL=http://localhost:3001

# Indexer API (for SSE real-time updates)
VITE_INDEXER_URL=http://localhost:3001

# Supabase (for notification preferences)
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_key>

# Pinata IPFS (optional — for document storage via IPFS)
# Get keys at https://app.pinata.cloud/keys
# If not set, falls back to SHA-256 hash stored on-chain
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET=

# Sentry (optional — for error tracking in production)
# Get DSN at https://sentry.io (free tier available)
# If not set, errors will only appear in browser console
VITE_SENTRY_DSN=

VITE_ETHERFUSE_RAMP_URL=
